# ─────────────────────────────────────────────
#  Codity Jobs — Environment Configuration
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=codity_jobs
DATABASE_USER=codity
DATABASE_PASSWORD=codity_secret
DATABASE_URL=postgresql://codity:codity_secret@localhost:5432/codity_jobs

# ── API Server ────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── Worker ────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_CONCURRENCY=5

# ── Scheduler ─────────────────────────────────
SCHEDULER_TICK_INTERVAL_MS=60000

# ── Dashboard ─────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
